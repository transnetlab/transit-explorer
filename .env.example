# Copy this file to `.env` (or create `.env.local`) and adjust values.
# Vite only exposes env vars prefixed with VITE_

# Prefer local APIs by default (city port decides which local service is used)
VITE_API_PREFERRED=local

# Local backend host (port is selected per city: Bengaluru=3000, Paris=3001, ...)
VITE_LOCAL_HOST=http://31.97.230.42
VITE_LOCAL_DEFAULT_PORT=3001

# Official TransitX gateway base URLs (used as fallback when local fails)
VITE_API_1_BASE=https://api.transitx.org/api_1
VITE_API_2_BASE=https://api.transitx.org/api_2
VITE_API_3_BASE=https://api.transitx.org/api_3

# Legacy (still supported): single local base; prefer VITE_LOCAL_HOST/VITE_LOCAL_DEFAULT_PORT
# VITE_LOCAL_GATEWAY_BASE=http://31.97.230.42:3001
