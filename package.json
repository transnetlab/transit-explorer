{
  "name": "route-finder-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:3000 && electron ./electron/main.js\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "electron ./electron/main.js",
    "build:electron": "electron-builder -w"
  },
  "dependencies": {
    "@svar-ui/react-gantt": "^2.3.4",
    "axios": "^1.6.7",
    "electron-is-dev": "^3.0.1",
    "firebase": "^12.8.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.344.0",
    "maplibre-gl": "^5.20.1",
    "plotly.js-dist-min": "^3.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-modal": "^3.16.3",
    "react-plotly.js": "^2.6.0",
    "react-router-dom": "^7.5.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/leaflet": "^1.9.8",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/react-modal": "^3.16.3",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^9.1.2",
    "electron": "^36.1.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  },
  "build": {
    "asar": false,
    "appId": "com.transitexplorer.app",
    "productName": "Transit Explorer",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      {
        "from": "electron",
        "to": "electron",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
